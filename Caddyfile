# =============================================================================
# Caddyfile - Reverse Proxy for MCP Proxy Stack
# =============================================================================
#
# Routes all traffic through the API Gateway for centralized authentication
# and rate limiting.
#
# Architecture:
#   Browser -> Caddy -> API Gateway -> Backend Services
#
# =============================================================================

{
	# Disable admin API (not needed for this use case)
	admin off

	# Custom-domain on-demand TLS — gated by tasks service ask endpoint
	on_demand_tls {
		ask http://tasks:8210/__caddy/check_ask
	}

	# Enable debug logging (set to warn in production)
	log {
		level INFO
	}
}

# =============================================================================
# HTTP Server (Port 80)
# =============================================================================
# For local development. In production, use HTTPS with automatic certs.

:80 {
	# Log all requests
	log {
		output stdout
		format console
	}

	# ---------------------------------------------------------------------------
	# Wildcard publishing — <slug>.ai-ui.coolestdomain.win serves files from
	# the apps/<slug>/ directory. The tasks service enforces published state.
	# ---------------------------------------------------------------------------
	@aiui_pub_subdomain {
		header_regexp Host ^(?P<aiui_slug>[a-z0-9][a-z0-9-]{1,80})\.ai-ui\.coolestdomain\.win$
	}
	handle @aiui_pub_subdomain {
		header Cache-Control "public, max-age=120"
		rewrite * /__public/{re.aiui_pub_subdomain.aiui_slug}{uri}
		reverse_proxy tasks:8210
	}

	# ---------------------------------------------------------------------------
	# Block vulnerability scanners (PHP, CGI, shell exploits)
	# ---------------------------------------------------------------------------
	@scanners {
		path /vendor/* /phpunit/* /lib/phpunit/* /cgi-bin/* /wp-admin/* /wp-login*
		path /.env /.git/* /config.php /admin.php /shell* /eval-stdin*
		path /laravel/* /yii/* /zend/* /drupal/* /wordpress/*
	}
	handle @scanners {
		respond 404
	}

	# ---------------------------------------------------------------------------
	# Health check endpoints (bypass gateway)
	# ---------------------------------------------------------------------------
	handle /health {
		respond "OK" 200
	}

	handle /caddy/health {
		respond "Caddy OK" 200
	}

	# ---------------------------------------------------------------------------
	# Gateway health (direct to gateway)
	# ---------------------------------------------------------------------------
	handle /gateway/* {
		reverse_proxy api-gateway:8080
	}

	# ---------------------------------------------------------------------------
	# MCP Proxy routes (through gateway)
	# ---------------------------------------------------------------------------
	# All MCP endpoints require authentication
	handle /mcp/* {
		reverse_proxy api-gateway:8080
	}

	handle /servers* {
		uri replace /servers /mcp/servers
		reverse_proxy api-gateway:8080
	}

	handle /meta/* {
		uri replace /meta /mcp/meta
		reverse_proxy api-gateway:8080
	}

	handle /openapi.json {
		uri replace /openapi.json /mcp/openapi.json
		reverse_proxy api-gateway:8080
	}

	# ---------------------------------------------------------------------------
	# Admin Portal routes (through gateway)
	# ---------------------------------------------------------------------------
	# /mcp-admin is the single admin portal URL
	handle /mcp-admin {
		reverse_proxy api-gateway:8080
	}

	handle /mcp-admin/* {
		reverse_proxy api-gateway:8080
	}

	handle /admin/* {
		reverse_proxy api-gateway:8080
	}

	# /portal redirects to /mcp-admin (handled by API Gateway)
	handle /portal* {
		reverse_proxy api-gateway:8080
	}

	# ---------------------------------------------------------------------------
	# Webhook Handler (external webhooks)
	# ---------------------------------------------------------------------------
	handle /webhook/* {
		reverse_proxy webhook-handler:8086 {
			header_down Cache-Control "no-store, no-cache, must-revalidate"
		}
	}

	# ---------------------------------------------------------------------------
	# Tasks Service — admin task approval panel
	# ---------------------------------------------------------------------------
	# /api/tasks/* goes through the gateway so JWT becomes X-User-Email
	handle /api/tasks/* {
		reverse_proxy api-gateway:8080
	}
	# /api/supabase/* (OAuth callback + future endpoints) → gateway → tasks
	handle /api/supabase/* {
		reverse_proxy api-gateway:8080
	}
	# Managed public app links returned by Publish in Discord/Slack.
	# The tasks service enforces the published_apps access gate.
	handle /apps/* {
		header Cache-Control "public, max-age=120"
		reverse_proxy tasks:8210
	}
	# Static frontend (panel JS + history page) — public, no auth on assets
	handle /tasks/static/* {
		header Cache-Control "no-cache, no-store, must-revalidate"
		header Pragma "no-cache"
		header Expires "0"
		reverse_proxy tasks:8210
	}

	# Liveness probe — used by scripts/deploy_orchestrator.sh post-deploy smoke.
	# Without this handler, /tasks/healthz would fall through to the Open WebUI
	# SPA catch-all (returns 200 + HTML), giving a false positive in deploys.
	# The tasks service has /healthz at root (not /tasks/healthz), so strip prefix.
	handle /tasks/healthz {
		uri strip_prefix /tasks
		reverse_proxy tasks:8210
	}

	# No-login video download deep links — the share_url the video bot posts in
	# Discord. The tasks /download endpoint authorizes via a signed ?cap=
	# capability bound to one (owner, slug, job_id), so it needs no gateway/JWT.
	# SECURITY (same rationale as /tasks/schedules*): strip identity headers so
	# this public route can ONLY be used with a valid capability — never to
	# impersonate a user via a forged X-User-Email/X-User-Admin. Scoped by regex
	# to the download path only; every other /api/video-jobs/* call still goes
	# through the gateway (/api/tasks/* or the SPA's cookie-authed fetch).
	@video_dl path_regexp ^/tasks/api/video-jobs/[^/]+/download$
	handle @video_dl {
		uri strip_prefix /tasks
		request_header -X-User-Email
		request_header -X-User-Admin
		reverse_proxy tasks:8210
	}

	# Schedules API (heartbeat scheduler) — protected by X-Cron-Secret header
	# inside the tasks service itself, so no gateway/JWT step needed here.
	# Tasks service exposes /schedules at root, so strip /tasks prefix.
	#
	# SECURITY: strip X-User-Email from any client request here. Only the
	# api-gateway is allowed to set that header (after JWT validation);
	# end users reach the schedules API via /api/tasks/schedules which goes
	# through the gateway. Without this strip, an attacker could send
	# `X-User-Email: someone-else@x.com` directly to /tasks/schedules and
	# impersonate that user. Belt-and-braces — the tasks service should
	# also defense-in-depth verify, but the perimeter strip is critical.
	handle /tasks/schedules* {
		uri strip_prefix /tasks
		request_header -X-User-Email
		reverse_proxy tasks:8210
	}

	# App Builder page — pretty URL that serves the projects SPA
	handle /tasks/app-builder {
		header Cache-Control "no-cache, no-store, must-revalidate"
		header Pragma "no-cache"
		reverse_proxy tasks:8210
	}

	# Inject Supabase window vars into the preview-app via a special URL.
	# This MUST come before the catch-all /tasks/preview-app/* below — Caddy
	# routes by most-specific match and we want this to hit tasks:8210 (the
	# FastAPI service) instead of tasks:9100 (the user's dev server).
	handle /tasks/preview-app/aiui-config.js {
		rewrite * /__preview_config.js
		header Cache-Control "no-store"
		reverse_proxy tasks:8210
	}

	# Preview app — FastAPI on 8210 handles both static apps (serve from
	# disk) and dynamic apps (reverse-proxy to per-slug ports 9100-9119
	# internally). Don't strip the prefix — FastAPI expects the full path.
	handle /tasks/preview-app/* {
		reverse_proxy tasks:8210
	}

	# ---------------------------------------------------------------------------
	# Google Drive MCP connector (via api-gateway for X-User-Email injection)
	# ---------------------------------------------------------------------------
	handle /gdrive/* {
		reverse_proxy api-gateway:8080
	}

	# ---------------------------------------------------------------------------
	# Gmail MCP connector (via api-gateway for X-User-Email injection)
	# ---------------------------------------------------------------------------
	handle /gmail/* {
		reverse_proxy api-gateway:8080
	}

	# ---------------------------------------------------------------------------
	# Google Calendar MCP connector (via api-gateway for X-User-Email injection)
	# ---------------------------------------------------------------------------
	handle /calendar/* {
		reverse_proxy api-gateway:8080
	}

	# ---------------------------------------------------------------------------
	# Meetings MCP — meeting transcript storage (via api-gateway for X-User-Email injection)
	# ---------------------------------------------------------------------------
	handle /meetings/* {
		reverse_proxy api-gateway:8080
	}

	# ---------------------------------------------------------------------------
	# Web Search MCP connector (via api-gateway for X-User-Email injection)
	# ---------------------------------------------------------------------------
	handle /web-search/* {
		reverse_proxy api-gateway:8080
	}

	# ---------------------------------------------------------------------------
	# Meeting KB MCP search/list/get (separate from legacy /mcp/meeting-kb/api/* uploader)
	# (via api-gateway for X-User-Email injection)
	# ---------------------------------------------------------------------------
	handle /meeting-kb/* {
		reverse_proxy api-gateway:8080
	}

	# ---------------------------------------------------------------------------
	# Dashboard MCP (via api-gateway for X-User-Email injection)
	# ---------------------------------------------------------------------------
	handle /dashboard/* {
		reverse_proxy api-gateway:8080
	}

	# ---------------------------------------------------------------------------
	# Excel-Creator MCP (via api-gateway for X-User-Email injection)
	# ---------------------------------------------------------------------------
	handle /excel-creator/* {
		reverse_proxy api-gateway:8080
	}

	# ---------------------------------------------------------------------------
	# MCP Remote — Claude Desktop external access (API key auth)
	# ---------------------------------------------------------------------------
	handle /mcp-remote/* {
		uri strip_prefix /mcp-remote
		reverse_proxy mcp-auth:8000
	}

	# ---------------------------------------------------------------------------
	# n8n Workflow Engine (external webhook triggers)
	# ---------------------------------------------------------------------------
	handle /n8n/* {
		uri strip_prefix /n8n
		reverse_proxy n8n:5678
	}

	# ---------------------------------------------------------------------------
	# Grafana - Log Dashboard (bypass gateway, direct to grafana)
	# ---------------------------------------------------------------------------
	handle /grafana/* {
		reverse_proxy grafana:3000
	}

	# ---------------------------------------------------------------------------
	# Static assets (bypass gateway to avoid rate limiting)
	# ---------------------------------------------------------------------------
	handle /_app/* {
		reverse_proxy open-webui:8080
	}

	handle /static/* {
		reverse_proxy open-webui:8080
	}

	handle /favicon* {
		reverse_proxy open-webui:8080
	}

	handle /manifest.json {
		reverse_proxy open-webui:8080
	}

	# ---------------------------------------------------------------------------
	# WebSocket (bypass gateway)
	# ---------------------------------------------------------------------------
	handle /ws/* {
		reverse_proxy open-webui:8080
	}

	# ---------------------------------------------------------------------------
	# Open WebUI (default, through gateway for auth)
	# ---------------------------------------------------------------------------
	handle /* {
		reverse_proxy api-gateway:8080
	}
}

# =============================================================================
# HTTPS Server (Port 443) - For Production
# =============================================================================
# Uncomment and configure for production deployment with automatic HTTPS.
#
# app.example.com {
# 	# Automatic HTTPS via Let's Encrypt
#
# 	# Same routing as above
# 	handle /gateway/* {
# 		reverse_proxy api-gateway:8080
# 	}
#
# 	handle /mcp/* {
# 		reverse_proxy api-gateway:8080
# 	}
#
# 	handle /admin/* {
# 		reverse_proxy api-gateway:8080
# 	}
#
# 	handle /* {
# 		reverse_proxy api-gateway:8080
# 	}
# }

# =============================================================================
# HTTPS Server (Port 443) — Custom user domains via on-demand TLS
# =============================================================================
# When a user attaches their own domain (e.g. mybrand.com) to a published
# app and points DNS at our server, Caddy auto-provisions a Let's Encrypt
# cert via on_demand TLS. The /__caddy/check_ask gatekeeper above ensures
# certs are issued ONLY for domains verified in tasks.published_apps.

:443 {
	tls {
		on_demand
	}

	log {
		output stdout
		format console
	}

	# Don't serve our own domains here — they go through Cloudflare on :80.
	@aiui_apex host coolestdomain.win *.coolestdomain.win
	handle @aiui_apex {
		respond 404
	}

	# Custom user domains — preserve Host so the backend can resolve to slug.
	handle {
		rewrite * /__public_by_host{uri}
		reverse_proxy tasks:8210 {
			header_up X-Forwarded-Host {host}
		}
	}
}
